export PREFIX=$HOME/local
#nproc=$( cat /proc/cpuinfo |grep processor|wc -l )
nproc=1

export PATH=$HOME/spm:$PREFIX/bin:$PREFIX/gnulib:$PREFIX/bootstrap/usr/bin:$PREFIX/bootstrap/bin:$PATH
export LIBDIR=$LIBDIR:$PREFIX/lib
export LD_LIBRARY_PATH=$PREFIX/lib
#export CC="gcc --sysroot $PREFIX/bootstrap/usr/lib64 -B $PREFIX/bootstrap/usr/lib/gcc/x86_64-redhat-linux/4.4.7/include/ -B /usr"

# build flags
CFLAGS="-mtune=generic -O2 -pipe -I. -I.. -I../.. -I../include -Iinclude -I$PREFIX/include -I$PREFIX/bootstrap/usr/include -L$PREFIX -L$PREFIX/lib"
#CPPFLAGS="-U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=2 ${CFLAGS}"
CXXFLAGS="$CFLAGS"
LDFLAGS="-Wl,-O1,--sort-common,--as-needed,-z,relro,--rpath=$PREFIX/lib -L$PREFIX -L$PREFIX/lib"
MAKEFLAGS="-j$((${nproc}+1))"

export CFLAGS CXXFLAGS CPPFLAGS LDFLAGS MAKEFLAGS
